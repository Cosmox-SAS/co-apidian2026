{
    "name": "facturalatam/apidian",
    "type": "project",
    "description": "API de Facturación Electrónica para Colombia (DIAN)",
    "keywords": ["laravel", "soap", "dian", "ubl", "api"],
    "license": "LGPL-3.0",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "aws/aws-sdk-php": "^3.231",
        "barryvdh/laravel-dompdf": "^2.0",
        "darkaonline/l5-swagger": "^8.6.5",
        "doctrine/dbal": "^3.0",
        "jurosh/pdf-merge": "^1.0",
        "laravel/framework": "^10.0",
        "laravel/tinker": "^2.7",
        "laravel/ui": "^4.6",
        "league/flysystem-aws-s3-v3": "^3.0",
        "mpdf/mpdf": "^8.0.13",
        "mtownsend/request-xml": "^2.6.0",
        "piotrooo/wsdl-creator": "^3.0",
        "rap2hpoutre/laravel-log-viewer": "^2.3",
        "simplesoftwareio/simple-qrcode": "^2.0",
        "spatie/flysystem-dropbox": "^3.0",
        "spatie/laravel-backup": "^8.5",
        "symfony/browser-kit": "^7.3",
        "ubl21dian/torresoftware": "dev-master"
    },
    "require-dev": {
        "fakerphp/faker": "^1.21",
        "filp/whoops": "^2.14",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5.10"
    },
    "autoload": {
        "classmap": [
            "database/seeders",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php -r \"if (file_exists('artisan')) passthru('php artisan package:discover');\""
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    }
}
